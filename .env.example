# ---- Anthropic (the curator brain) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Cheap + fast is plenty for parsing/curation. Bump to a Sonnet/Opus model for richer picks.
CURATOR_MODEL=claude-haiku-4-5-20251001

# ---- Google / YouTube OAuth (one-time, OFFLINE access) ----
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
# Filled in by running:  python -m scripts.connect_youtube
# (sign in with the account playlists should be published to — e.g. the gym's iPad account)
YOUTUBE_REFRESH_TOKEN=

# ---- AWS Cognito (login / app gate) ----
COGNITO_REGION=eu-central-1
COGNITO_USER_POOL_ID=eu-central-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxx

# ---- Access control ----
# Comma-separated allow-list. Only these emails (from the Cognito ID token) may use the app.
ALLOWED_EMAILS=you@example.com,friend@example.com

# ---- App ----
TARGET_REGION=IL          # drop videos blocked in this region
DB_PATH=./wod2beats.db

# ---- Frontend (baked into the React build) ----
# URL the browser uses to reach the API (no trailing slash)
VITE_API_BASE_URL=http://77.42.123.217:8232
# Simple login gate for the test environment
VITE_APP_USER=gym
VITE_APP_PASSWORD=changeme
